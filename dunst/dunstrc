[global]
    monitor = 0
    follow = mouse
    width = 350
    height = 300
    offset = 20x20
    origin = top-right

    frame_width = 2
    corner_radius = 10

    font = JetBrainsMono Nerd Font Mono 10

    idle_threshold = 120

    separator_height = 2
    padding = 10
    horizontal_padding = 10

    show_age_threshold = 60

    markup = full

    format = "<b>%s</b>\n%b"

    sort = yes

    shrink = yes

    transparency = 0

    timeout = 3